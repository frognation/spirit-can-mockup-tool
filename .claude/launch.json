{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev",
      "runtimeExecutable": "node_modules/.bin/next",
      "runtimeArgs": ["dev"],
      "port": 3000
    },
    {
      "name": "Electron + Next.js Dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "electron:dev"],
      "port": 3000
    },
    {
      "name": "Next.js Production",
      "runtimeExecutable": "node_modules/.bin/next",
      "runtimeArgs": ["start"],
      "port": 3000
    }
  ]
}
